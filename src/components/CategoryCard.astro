---
type Props = {
	title: string;
	href: string;
	description: string;
	image: string;
	imageAlt: string;
	tag?: string;
	slug?: string;
};

const { title, href, description, image, imageAlt, tag, slug } = Astro.props;
---

<article class:list={['category-card', slug === 'produkte-fuer-den-urlaub' && 'category-card--wide']}>
	<a href={href} aria-label={`${title} öffnen`}>
		<img src={image} alt={imageAlt} loading="lazy" width="800" height="520" />
		<div class="category-card__body">
			{tag && <p class="category-card__tag">{tag}</p>}
			<h3>{title}</h3>
			<p>{description}</p>
		</div>
	</a>
</article>
