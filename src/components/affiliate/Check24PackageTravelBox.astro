---
import { affiliatePartners } from '../../data/travelDeals';

const check24 = affiliatePartners.check24;
---

<section class="affiliate-box affiliate-box--package" aria-labelledby="check24-pauschalreisen-title">
	<div class="affiliate-box__content">
		<p class="partner-label">{check24.disclosure}</p>
		<h2 id="check24-pauschalreisen-title">Pauschalreisen bei CHECK24 vergleichen</h2>
		<p>
			Über CHECK24 kannst du Pauschalreisen verschiedener Anbieter vergleichen. Achte immer auf Reisedatum,
			Gepäck, Transfer, Hotelbewertung und Stornobedingungen.
		</p>
		<a
			class="button button--primary"
			href={check24.links.packageTravel}
			target="_blank"
			rel="nofollow sponsored noopener noreferrer"
		>
			Pauschalreisen vergleichen
		</a>
	</div>
	<aside class="affiliate-box__banner" aria-label="CHECK24 Pauschalreisen Banner">
		<a
			href={check24.banners.packageTravel}
			target="_blank"
			rel="nofollow sponsored noopener noreferrer"
			aria-label="CHECK24 Pauschalreisen vergleichen"
		>
			<img
				src={check24.banners.packageTravelImage}
				width="120"
				height="600"
				alt="CHECK24 Pauschalreisen Vergleich"
				loading="lazy"
				decoding="async"
			/>
		</a>
	</aside>
</section>
