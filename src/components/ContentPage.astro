---
import AffiliateNotice from './AffiliateNotice.astro';
import CategoryCard from './CategoryCard.astro';
import DealCard from './DealCard.astro';
import Faq from './Faq.astro';
import TravelTipProductCard from './TravelTipProductCard.astro';
import Check24LastMinuteBox from './affiliate/Check24LastMinuteBox.astro';
import Check24PackageTravelBox from './affiliate/Check24PackageTravelBox.astro';
import Check24RentalCarBanner from './affiliate/Check24RentalCarBanner.astro';
import Check24RentalCarWidget from './affiliate/Check24RentalCarWidget.astro';
import { categoryPages } from '../data/site';
import { travelDeals } from '../data/travelDeals';
import { travelTipProducts } from '../data/travelTipProducts';
import type { PageContent } from '../data/pages';

type Props = {
	page: PageContent;
};

const { page } = Astro.props;
const relatedCards = page.relatedSlugs
	.map((slug) => categoryPages.find((category) => category.slug === slug))
	.filter(Boolean);
const pageDeals = travelDeals.filter((deal) => deal.category === page.dealCategory);
const hasInternalLinks = page.internalLinks && page.internalLinks.length > 0;
---

<section class="subhero">
	<img src={page.image} alt={page.imageAlt} width="1600" height="900" />
	<div class="subhero__overlay"></div>
	<div class="container subhero__content">
		<p class="eyebrow">{page.eyebrow}</p>
		<h1>{page.h1}</h1>
		<p>{page.intro}</p>
	</div>
</section>

<main>
	<section class="section">
		<div class="container split-layout">
			<div class="copy-block">
				<p class="eyebrow">Ratgeber</p>
				<h2>{page.adviceTitle}</h2>
				{page.body.map((paragraph) => <p>{paragraph}</p>)}
			</div>
			<aside class="info-panel">
				<h2>Keine Lockangebote</h2>
				<p>
					Auf dieser Seite werden keine erfundenen Preise, Rabatte oder Testsieger angezeigt. Angebotsplätze
					bleiben Platzhalter, bis echte Affiliate-Daten oder manuell geprüfte Links vorliegen.
				</p>
			</aside>
		</div>
	</section>

	{
		page.slug === 'last-minute-urlaub' && (
			<section class="section section--affiliate">
				<div class="container">
					<Check24LastMinuteBox />
				</div>
			</section>
		)
	}

	{
		page.slug === 'pauschalreisen' && (
			<section class="section section--affiliate">
				<div class="container">
					<Check24PackageTravelBox />
				</div>
			</section>
		)
	}

	<section class="section section--sand">
		<div class="container">
			<div class="section-heading">
				<p class="eyebrow">Kategorien</p>
				<h2>Passende Reisekategorien</h2>
			</div>
			<div class="category-grid category-grid--compact">
				{relatedCards.map((card) => card && <CategoryCard {...card} />)}
			</div>
			{
				hasInternalLinks && (
					<div class="related-link-list">
						{page.internalLinks?.map((link) => (
							<a href={link.href}>
								<strong>{link.title}</strong>
								<span>{link.description}</span>
							</a>
						))}
					</div>
				)
			}
		</div>
	</section>

	{
		page.slug === 'mietwagen' && (
			<section class="section section--affiliate">
				<div class="container affiliate-stack">
					<Check24RentalCarWidget />
					<Check24RentalCarBanner />
				</div>
			</section>
		)
	}

	{
		pageDeals.length > 0 && (
			<section class="section">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">Angebotsplätze</p>
						<h2>Geprüfte Partnerlinks und vorbereitete Angebotskarten</h2>
						<p>
							Echte Partnerlinks sind klar gekennzeichnet. Platzhalter bleiben deaktiviert, bis der jeweilige
							Partnerlink geprüft und als bereit markiert ist.
						</p>
					</div>
					<div class="deal-grid">
						{pageDeals.map((deal) => <DealCard deal={deal} />)}
					</div>
				</div>
			</section>
		)
	}

	<section class="section section--blue">
		<div class="container">
			<div class="section-heading section-heading--light">
				<p class="eyebrow">Spartipps</p>
				<h2>So sparst du bei dieser Reiseart</h2>
			</div>
			<div class="tips-grid">
				{page.tips.map((tip, index) => (
					<article>
						<span>{String(index + 1).padStart(2, '0')}</span>
						<p>{tip}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	{
		page.slug === 'reisetipps' && (
			<section class="section section--sand travel-tip-products">
				<div class="container">
					<div class="section-heading">
						<p class="eyebrow">Partner-Ratgeber</p>
						<h2>Reiseratgeber &amp; Insel-Guides</h2>
						<p>
							Hier findest du ausgewählte Reise-Ratgeber, Bildbände und Insel-Guides. Die Links führen zu
							externen Partnerseiten. Prüfe vor dem Kauf immer selbst, ob Inhalt, Preis und Anbieter zu dir
							passen.
						</p>
					</div>
					<p class="travel-tip-products__notice">
						Hinweis: Die folgenden Karten enthalten Partnerlinks. Wenn du darüber kaufst, erhalten wir ggf. eine
						Provision. Für dich entstehen keine Mehrkosten.
					</p>
					<div class="travel-tip-grid">
						{travelTipProducts.map((product) => <TravelTipProductCard product={product} />)}
					</div>
				</div>
			</section>
		)
	}

	<Faq faqs={page.faqs} />

	<section class="section section--notice">
		<div class="container">
			<AffiliateNotice />
		</div>
	</section>
</main>
